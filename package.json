{
  "//pin-notes": {
    "typescript": "Tilde pin (~6.0.3): typescript-eslint peer dep caps at <6.1.0, so caret would pull 6.1.x and break tsc.",
    "eslint-plugin-react-hooks": "Caret pin (^7.1.1) since #310; ESLint 10 still blocked by eslint-plugin-react / jsx-a11y peer ranges (see #295)."
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "react-router build",
    "build:no-fetch": "cross-env DISABLE_CONTENTFUL_RUNTIME=true react-router build",
    "dev": "cross-env NODE_ENV=development node ./server/dev-server.js",
    "start": "netlify serve",
    "typecheck": "react-router typegen && tsc",
    "lint": "react-router typegen && eslint . -c ./config/eslint.config.js",
    "lint:fix": "react-router typegen && eslint . -c ./config/eslint.config.js --fix",
    "lint:fast": "oxlint -c ./config/oxlintrc.json --tsconfig=./tsconfig.json",
    "prepare": "husky",
    "format": "prettier --config ./config/prettier.config.mjs --ignore-path ./config/.prettierignore --write .",
    "format:check": "prettier --config ./config/prettier.config.mjs --ignore-path ./config/.prettierignore --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint -c ./config/oxlintrc.json --tsconfig=./tsconfig.json --fix",
      "eslint -c ./config/eslint.config.js --fix",
      "prettier --config ./config/prettier.config.mjs --ignore-path ./config/.prettierignore --write"
    ],
    "*.{json,md,mdx,css,yml,yaml}": [
      "prettier --config ./config/prettier.config.mjs --ignore-path ./config/.prettierignore --write"
    ]
  },
  "dependencies": {
    "@browser-bunyan/console-formatted-stream": "^1.8.0",
    "@netlify/blobs": "^10.7.9",
    "@netlify/functions": "^5.3.0",
    "@octokit/plugin-throttling": "^11.0.2",
    "@octokit/rest": "^22.0.1",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.17.0",
    "browser-bunyan": "^1.8.0",
    "contentful": "^11.12.5",
    "date-fns": "^4.4.0",
    "isbot": "^5.1.42",
    "nodemailer": "^8.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.0.1",
    "react-router": "^7.17.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-external-links": "^3.0.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^9.39.0",
    "@mjackson/node-fetch-server": "^0.7.0",
    "@netlify/vite-plugin-react-router": "^3.1.1",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.17.0",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^22.20.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/ui": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "netlify-cli": "^26.1.0",
    "oxlint": "^1.70.0",
    "prettier": "^3.9.4",
    "react-router-devtools": "^6.2.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.16",
    "vite-plugin-babel": "^1.7.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "prismjs": ">=1.30.0"
  }
}
