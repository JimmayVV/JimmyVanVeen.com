{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:no-fetch": "cross-env DISABLE_CONTENTFUL_RUNTIME=true react-router build",
    "dev": "cross-env NODE_ENV=development node ./server/dev-server.js",
    "start": "netlify serve",
    "typecheck": "react-router typegen && tsc",
    "lint": "react-router typegen && oxlint --type-aware -c ./config/oxlintrc.json --tsconfig=./tsconfig.json",
    "lint:fix": "react-router typegen && oxlint --type-aware -c ./config/oxlintrc.json --tsconfig=./tsconfig.json --fix",
    "lint:fast": "oxlint -c ./config/oxlintrc.json --tsconfig=./tsconfig.json",
    "prepare": "husky",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@browser-bunyan/console-formatted-stream": "^1.8.0",
    "@netlify/blobs": "^10.7.9",
    "@netlify/functions": "^5.3.0",
    "@octokit/plugin-throttling": "^11.0.2",
    "@octokit/rest": "^22.0.1",
    "@react-router/node": "^8.3.0",
    "@react-router/serve": "^8.3.0",
    "browser-bunyan": "^1.8.0",
    "contentful": "^11.12.5",
    "date-fns": "^4.4.0",
    "isbot": "^5.2.0",
    "nodemailer": "^9.0.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-markdown": "^10.0.1",
    "react-router": "^8.3.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-external-links": "^3.0.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.29.7",
    "@mjackson/node-fetch-server": "^0.7.0",
    "@netlify/vite-plugin-react-router": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^8.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/ui": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "netlify-cli": "^26.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "prettier": "^3.9.5",
    "react-router-devtools": "^6.2.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-node": "^6.0.0",
    "vite-plugin-babel": "^1.7.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "prismjs": ">=1.30.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --type-aware -c ./config/oxlintrc.json --tsconfig=./tsconfig.json --fix",
      "oxfmt"
    ],
    "*.{json,md,mdx,css,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
